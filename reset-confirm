<script>
  const SUPABASE_URL = 'https://vliuuloyfhyxcsuchpss.supabase.co';
  const SUPABASE_KEY = 'sb_publishable_oIIcecf3wzKMual5K24Z8Q_zmxVfgsx';
  const { createClient } = supabase;
  const db = createClient(SUPABASE_URL, SUPABASE_KEY);

  // ─────────────────────────────────────────
  // STATE MACHINE
  // ─────────────────────────────────────────
  function showState(id) {
    document.querySelectorAll('.state').forEach(s => s.classList.remove('active'));
    document.getElementById(id).classList.add('active');
  }

  // ─────────────────────────────────────────
  // INIT — Supabase handles the token from
  // the URL hash automatically on load.
  // We just need to check the session.
  // ─────────────────────────────────────────
  async function init() {
    // Give Supabase a moment to parse the hash tokens
    await new Promise(r => setTimeout(r, 800));

    const { data: { session }, error } = await db.auth.getSession();

    if (error || !session) {
      // Try parsing hash manually (older Supabase versions)
      const hash = window.location.hash;
      if (hash.includes('error=')) {
        showState('state-invalid');
        return;
      }
      // No session and no error in hash — might be a direct visit
      if (!hash.includes('access_token')) {
        showState('state-invalid');
        return;
      }
    }

    if (session) {
      showState('state-form');
    } else {
      showState('state-invalid');
    }
  }

  // Listen for auth state changes (Supabase fires PASSWORD_RECOVERY event)
  db.auth.onAuthStateChange((event, session) => {
    if (event === 'PASSWORD_RECOVERY') {
      showState('state-form');
    }
  });

  // ─────────────────────────────────────────
  // PASSWORD STRENGTH
  // ─────────────────────────────────────────
  function checkStrength(pw) {
    const rules = {
      'rule-len':   pw.length >= 8,
      'rule-upper': /[A-Z]/.test(pw),
      'rule-num':   /[0-9]/.test(pw),
      'rule-sym':   /[^A-Za-z0-9]/.test(pw),
    };
    const score = Object.values(rules).filter(Boolean).length;
    Object.entries(rules).forEach(([id, met]) =>
      document.getElementById(id).classList.toggle('met', met)
    );
    const bar   = document.getElementById('pw-bar');
    const label = document.getElementById('pw-strength-label');
    if (!pw) {
      bar.style.width = '0'; label.textContent = 'Enter a password to check strength'; label.style.color = '';
      return 0;
    }
    const levels = [
      { w:'25%', color:'#e74c3c', text:'Weak — add uppercase, numbers & symbols' },
      { w:'50%', color:'#e67e22', text:'Fair' },
      { w:'75%', color:'#d97706', text:'Good' },
      { w:'100%', color:'#16a34a', text:'Strong ✓' },
    ];
    const l = levels[score - 1] || levels[0];
    bar.style.width = l.w; bar.style.background = l.color;
    label.textContent = l.text; label.style.color = l.color;
    return score;
  }

  // ─────────────────────────────────────────
  // REAL-TIME MATCH INDICATOR
  // ─────────────────────────────────────────
  function checkMatch() {
    const pw1 = document.getElementById('pw-new').value;
    const pw2 = document.getElementById('pw-confirm').value;
    const indicator = document.getElementById('match-indicator');
    const text      = document.getElementById('match-text');
    if (!pw2) { indicator.className = 'match-indicator'; return false; }
    if (pw1 === pw2) {
      indicator.className = 'match-indicator show match';
      indicator.querySelector('svg').innerHTML = '<polyline points="20 6 9 17 4 12"/>';
      text.textContent = 'Passwords match';
      return true;
    } else {
      indicator.className = 'match-indicator show nomatch';
      indicator.querySelector('svg').innerHTML = '<line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>';
      text.textContent = 'Passwords do not match';
      return false;
    }
  }

  // ─────────────────────────────────────────
  // INPUT HANDLERS — enable button when valid
  // ─────────────────────────────────────────
  function onNewPw() {
    const pw = document.getElementById('pw-new').value;
    document.getElementById('err-pw-new').classList.remove('show');
    document.getElementById('pw-new').classList.remove('has-error');
    checkStrength(pw);
    updateSubmitBtn();
    if (document.getElementById('pw-confirm').value) checkMatch();
  }

  function onConfirmPw() {
    document.getElementById('err-pw-confirm').classList.remove('show');
    document.getElementById('pw-confirm').classList.remove('has-error');
    checkMatch();
    updateSubmitBtn();
  }

  function updateSubmitBtn() {
    const pw1   = document.getElementById('pw-new').value;
    const pw2   = document.getElementById('pw-confirm').value;
    const valid = pw1.length >= 8 && pw1 === pw2;
    document.getElementById('btn-submit').disabled = !valid;
  }

  // ─────────────────────────────────────────
  // SUBMIT
  // ─────────────────────────────────────────
  async function doReset() {
    const pw1 = document.getElementById('pw-new').value;
    const pw2 = document.getElementById('pw-confirm').value;
    const alertEl = document.getElementById('form-alert');
    alertEl.className = 'alert';

    // Validate
    let valid = true;
    if (pw1.length < 8) {
      document.getElementById('pw-new').classList.add('has-error');
      document.getElementById('err-pw-new').classList.add('show');
      valid = false;
    }
    if (pw1 !== pw2) {
      document.getElementById('pw-confirm').classList.add('has-error');
      document.getElementById('err-pw-confirm').classList.add('show');
      valid = false;
    }
    if (!valid) return;

    // Submit
    const btn = document.getElementById('btn-submit');
    btn.disabled = true; btn.classList.add('loading');

    const { error } = await db.auth.updateUser({ password: pw1 });

    btn.disabled = false; btn.classList.remove('loading');

    if (error) {
      alertEl.className = 'alert error';
      document.getElementById('form-alert-msg').textContent =
        error.message.includes('same password')
          ? 'New password must be different from your current password.'
          : error.message || 'Something went wrong. Please request a new reset link.';
      return;
    }

    // Sign out so they log in fresh with new password
    await db.auth.signOut();
    showState('state-success');
    startCountdown();
  }

  // ─────────────────────────────────────────
  // COUNTDOWN + AUTO-REDIRECT
  // ─────────────────────────────────────────
  function startCountdown() {
    let secs = 5;
    const circle = document.getElementById('countdown-circle');
    const number = document.getElementById('countdown-number');
    const circumference = 163; // 2 * π * 26

    circle.style.strokeDashoffset = '0';

    const interval = setInterval(() => {
      secs--;
      number.textContent = secs;
      // Animate ring draining
      const offset = circumference * (1 - secs / 5);
      circle.style.strokeDashoffset = offset;
      if (secs <= 0) {
        clearInterval(interval);
        window.location.href = 'login.html';
      }
    }, 1000);
  }

  // ─────────────────────────────────────────
  // EYE TOGGLE
  // ─────────────────────────────────────────
  function toggleEye(inputId, btn) {
    const input = document.getElementById(inputId);
    const show  = input.type === 'password';
    input.type  = show ? 'text' : 'password';
    btn.innerHTML = show
      ? `<svg viewBox="0 0 24 24"><path d="M17.94 17.94A10.07 10.07 0 0112 20c-7 0-11-8-11-8a18.45 18.45 0 015.06-5.94M9.9 4.24A9.12 9.12 0 0112 4c7 0 11 8 11 8a18.5 18.5 0 01-2.16 3.19"/><line x1="1" y1="1" x2="23" y2="23"/></svg>`
      : `<svg viewBox="0 0 24 24"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>`;
  }

  // ─────────────────────────────────────────
  // ENTER KEY
  // ─────────────────────────────────────────
  document.addEventListener('keydown', e => {
    if (e.key === 'Enter' && !document.getElementById('btn-submit').disabled) doReset();
  });

  // ─────────────────────────────────────────
  // BOOT
  // ─────────────────────────────────────────
  init();
</script>
</body>

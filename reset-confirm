<!-- ── CARD ── -->
<div class="center">
  <div class="card">

    <!-- STATE: Loading (while Supabase verifies the token) -->
    <div class="state active" id="state-loading">
      <div class="spinner-ring"></div>
      <p>Verifying your reset link…</p>
    </div>

    <!-- STATE: Invalid / expired link -->
    <div class="state" id="state-invalid">
      <div class="state-icon red">
        <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
      </div>
      <h2>Link expired or invalid</h2>
      <p>This password reset link has expired or has already been used.<br/>Reset links are valid for <strong>1 hour</strong> after they are sent.</p>
      <a href="login.html" style="
        display:inline-flex; align-items:center; gap:8px;
        width:100%; justify-content:center;

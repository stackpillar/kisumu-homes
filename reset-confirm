    </div>

    <!-- STATE: Reset form -->
    <div class="state" id="state-form">
      <div class="card-top">
        <div class="card-top-eyebrow">Secure reset</div>
        <h1>Set new password</h1>
        <p>Choose a strong password you haven't used before.</p>
      </div>
      <div class="card-body">

        <div class="alert" id="form-alert">
          <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
          <span id="form-alert-msg"></span>
        </div>

        <!-- New password -->
        <div class="form-group">
          <label for="pw-new">New password</label>
          <div class="input-wrap">
            <div class="input-icon"><svg viewBox="0 0 24 24"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg></div>
            <input type="password" id="pw-new" placeholder="At least 8 characters" autocomplete="new-password" oninput="onNewPw()"/>
            <button class="pw-eye" onclick="toggleEye('pw-new',this)" type="button" aria-label="Show password">
              <svg viewBox="0 0 24 24"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
            </button>
          </div>
          <div class="pw-strength">

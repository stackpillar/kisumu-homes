            <div class="pw-strength-label" id="pw-strength-label">Enter a password to check strength</div>
            <div class="pw-rules">
              <div class="pw-rule" id="rule-len">  <svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>8+ characters</div>
              <div class="pw-rule" id="rule-upper"><svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>Uppercase letter</div>
              <div class="pw-rule" id="rule-num">  <svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>A number</div>
              <div class="pw-rule" id="rule-sym">  <svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>A symbol (!@#…)</div>
            </div>
          </div>
          <div class="field-error" id="err-pw-new">Password must be at least 8 characters.</div>
        </div>

        <!-- Confirm password -->
        <div class="form-group" style="margin-top:18px">
          <label for="pw-confirm">Confirm password</label>
          <div class="input-wrap">
            <div class="input-icon"><svg viewBox="0 0 24 24"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg></div>
            <input type="password" id="pw-confirm" placeholder="Repeat your new password" autocomplete="new-password" oninput="onConfirmPw()"/>
            <button class="pw-eye" onclick="toggleEye('pw-confirm',this)" type="button" aria-label="Show password">
              <svg viewBox="0 0 24 24"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
            </button>
          </div>
          <div class="match-indicator" id="match-indicator">
            <svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>
            <span id="match-text"></span>
          </div>
          <div class="field-error" id="err-pw-confirm">Passwords do not match.</div>
        </div>

        <button class="btn-submit" id="btn-submit" onclick="doReset()" disabled>
          <div class="spinner"></div>
          <span class="btn-label">
            <svg viewBox="0 0 24 24" style="width:15px;height:15px;stroke:white;fill:none;stroke-width:2;display:inline;vertical-align:middle;margin-right:4px"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            Save new password
          </span>
        </button>

        <div class="back-link">
          <a href="login.html">← Back to sign in</a>
        </div>
      </div>
    </div>

    <!-- STATE: Success -->
    <div class="state" id="state-success">
      <div class="state-icon green" style="margin:0 auto 20px">
        <svg viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg>
      </div>
      <h2>Password updated!</h2>
      <p>Your password has been changed successfully.<br/>Redirecting you to sign in…</p>
      <div class="countdown-ring">
        <svg width="64" height="64" viewBox="0 0 64 64">
          <circle cx="32" cy="32" r="26"/>
          <circle cx="32" cy="32" r="26" class="progress" id="countdown-circle"/>
        </svg>
        <div class="countdown-number" id="countdown-number">5</div>
      </div>
      <a href="login.html" class="btn-dashboard">
        <svg viewBox="0 0 24 24"><path d="M15 3h4a2 2 0 012 2v14a2 2 0 01-2 2h-4"/><polyline points="10 17 15 12 10 7"/><line x1="15" y1="12" x2="3" y2="12"/></svg>
        Sign in now
      </a>
    </div>

  </div>
</div>

